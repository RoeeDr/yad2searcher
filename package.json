{
  "name": "yad2searcher",
  "version": "1.0.0",
  "description": "Yad2 apartment rental crawler and alerter",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "crawl-once": "CRAWL_ONCE=true node dist/index.js",
    "clean-db": "node -e \"const{MongoClient}=require('mongodb');const c=new MongoClient(process.env.MONGO_URI||'mongodb://localhost:27017');c.connect().then(()=>c.db(process.env.MONGO_DB_NAME||'yad2searcher').collection(process.env.MONGO_COLLECTION||'listings').drop()).then(()=>{console.log('DB cleaned');c.close()}).catch(e=>{if(e.codeName==='NamespaceNotFound')console.log('DB already clean');else console.error(e);c.close()})\""
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "mongodb": "^6.12.0",
    "playwright": "^1.52.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
