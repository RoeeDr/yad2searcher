# Required: Yad2 search URL(s) — comma-separated for multiple searches
YAD2_SEARCH_URL=https://www.yad2.co.il/realestate/rent?city=5000&rooms=2-4&price=3000-8000

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=yad2searcher
MONGO_COLLECTION=listings

# Crawler behavior
CRAWL_INTERVAL_MIN_MINUTES=10
CRAWL_INTERVAL_MAX_MINUTES=20
HEADLESS=true
FETCH_DETAILS=false
MIN_PAGE_DELAY_MS=3000
MAX_PAGE_DELAY_MS=8000

# Run once and exit (useful for testing)
CRAWL_ONCE=false

# Telegram (optional - leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
