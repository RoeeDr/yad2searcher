# Mode: "static" (URLs from env) or "dynamic" (URLs from Telegram users)
APP_MODE=static

# Required in static mode: Yad2 search URL(s) — comma-separated for multiple searches
YAD2_SEARCH_URL=https://www.yad2.co.il/realestate/rent?city=5000&rooms=2-4&price=3000-8000,

# Crawler behavior
CRAWL_INTERVAL_MIN_MINUTES=10
CRAWL_INTERVAL_MAX_MINUTES=20
HEADLESS=true
FETCH_DETAILS=false
MIN_PAGE_DELAY_MS=3000
MAX_PAGE_DELAY_MS=8000

# Run once and exit (useful for testing)
CRAWL_ONCE=false

# Telegram (optional in static mode, bot token required in dynamic mode)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
